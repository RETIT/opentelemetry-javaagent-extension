<!--
    This beans.xml enables CDI bean discovery for the RETIT instrumentation library JAR.

    bean-discovery-mode="annotated" means only classes explicitly annotated with CDI
    scope annotations (such as @ApplicationScoped) are discovered.  This is intentional:
    we want the CDI container to pick up RETITSpanProcessorConfiguration automatically
    without scanning every class in the library.

    Quarkus, WildFly, GlassFish and other standard CDI containers respect this file when
    the library JAR is placed on the classpath (e.g. as a Maven dependency).
-->
<beans xmlns="https://jakarta.ee/xml/ns/jakartaee"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                           https://jakarta.ee/xml/ns/jakartaee/beans_4_0.xsd"
       bean-discovery-mode="annotated"
       version="4.0">
</beans>

